TELEGRAM_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_CHAT_ID=-1001234567890
TARGET_URL=https://hazpost.app
MONITOR_BASE_URL=https://monitor.hazpost.app
SECRET_KEY=change-this-to-a-random-secret-key
PORT=5000
LOG_LEVEL=INFO

# Modo de operación: "prueba" (simula, no escribe) o "produccion" (escribe)
MODO=produccion

# Almacenamiento: "local" hoy, "s3" cuando escale
BACKUP_STORAGE=local

# Base de datos: SQLite hoy, cambiar a postgresql:// cuando escale
DATABASE_URL=sqlite:///data/hazpost.db

# Cola de tareas: vacío hoy, redis://localhost:6379 cuando escale
REDIS_URL=

# Intervalos del scheduler
SCAN_INTERVAL_HOURS=6
MONITOR_INTERVAL_MINUTES=5
BACKUP_HOUR=2
DAILY_SUMMARY_HOUR=9
RATE_LIMIT_LOGIN=5 per minute

# Umbral de similitud para fusión de conocimiento colectivo (0-100)
COLECTIVO_SIMILARITY_THRESHOLD=75

# Contraseña para el panel de administración en /admin
ADMIN_PASSWORD=change-this-to-a-secure-password
