# ============================================================
# HazPost Backend — Variables de Entorno
# Copia este archivo como .env y completa los valores reales
# NUNCA comitees el archivo .env al repositorio
# ============================================================

# --- Flask ---
SECRET_KEY=cambia-esto-por-una-clave-secreta-aleatoria-larga
FLASK_DEBUG=false
PORT=5000

# --- Sitio objetivo a monitorear ---
TARGET_SITE=https://hazpost.app

# --- Telegram Bot ---
# Obtén el token creando un bot con @BotFather en Telegram
# El chat_id puede ser el ID de un canal, grupo o usuario
TELEGRAM_BOT_TOKEN=1234567890:ABCDefGHIJKLMNopQRSTUVWXyz1234567890
TELEGRAM_CHAT_ID=-1001234567890

# --- Backups ---
# Días de retención de backups locales (los más antiguos se eliminan)
BACKUP_RETENTION_DAYS=30

# Directorio donde se almacenan datos y backups
DATA_DIR=./data

# --- Seguridad ---
# Clave API para proteger todos los endpoints POST/DELETE (escritura).
# Los endpoints GET de solo lectura (/, /health, /api/monitor/, etc.) son siempre públicos.
# Si está vacía, la autenticación queda desactivada (útil solo para desarrollo local).
# Genera una clave segura: python -c "import secrets; print(secrets.token_hex(32))"
# Envía en cada request de escritura con el header: X-API-Key: <tu_clave>
API_KEY=

# --- APScheduler ---
# Intervalo de escaneo completo en horas (default: 6)
SCAN_INTERVAL_HOURS=6

# Intervalo de verificación de estado del sitio en minutos (default: 5)
MONITOR_INTERVAL_MINUTES=5

# Hora diaria para ejecutar el backup (formato: HH en UTC, default: 02)
BACKUP_HOUR_UTC=2
